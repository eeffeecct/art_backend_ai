# Copy to .env and fill in real values. NEVER commit the real .env.
POSTGRES_DB=art_postgres_db
POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me

RABBITMQ_DEFAULT_USER=change_me
RABBITMQ_DEFAULT_PASS=change_me

MINIO_ROOT_USER=change_me
MINIO_ROOT_PASSWORD=change_me

# JWT signing secret — MUST be at least 32 bytes (characters). Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes
# Comma-separated list of allowed frontend origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# MinIO host the browser uses to load images (localhost for local dev).
MINIO_PUBLIC_HOST=localhost
